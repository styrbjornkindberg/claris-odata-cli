{
  "name": "@claris/odata-cli",
  "version": "1.0.0",
  "description": "CLI tool for working with Claris FileMaker OData API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fmo": "./dist/index.js",
    "fmodata": "./dist/index.js",
    "fmodata-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "mcp": "node dist/mcp-server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:browse": "vitest run tests/unit/cli/browse.tty.test.ts tests/unit/cli/browse.server-selection.test.ts tests/unit/cli/browse.credentials.test.ts tests/unit/cli/browse.database-selection.test.ts tests/unit/cli/browse.table-selection.test.ts tests/unit/cli/browse.action-menu.test.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/seldon-enterprises/claris-odata-cli.git"
  },
  "keywords": [
    "claris",
    "filemaker",
    "odata",
    "cli"
  ],
  "author": "Seldon Enterprises",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "keytar": "^7.9.0",
    "zod": "^4.0.0"
  }
}

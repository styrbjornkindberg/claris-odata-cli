# FileMaker Integration Test Configuration
#
# Copy this file to .env and fill in your values
# Tests will create/destroy databases on this server

# FileMaker Server
FM_SERVER=https://your-server.example.com
FM_DATABASE=your_existing_database    # Database must already exist (OData can't create databases)

# OData Credentials (must have schema modification permissions)
FM_USERNAME=your_username
FM_PASSWORD=your_password

# Test Configuration
TEST_CLEANUP=truncate      # 'truncate' = clear tables after tests, 'none' = leave data
TEST_TIMEOUT=30000         # 30 second timeout for operations
TEST_DB_PREFIX=test_       # Database name prefix (test_claris_odata_cli)

# Optional: Run specific tests only
# TEST_TABLES=Customers,Orders,Products